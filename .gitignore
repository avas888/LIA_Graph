# --- run logs (volatile; regenerate on each ingest run) ---
logs/events.jsonl
logs/api_audit.jsonl
logs/chat_verbose.jsonl
logs/reasoning_events.jsonl
logs/ingest_*.log
logs/embeddings_*.log
logs/backfill_*.log
