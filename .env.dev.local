# Local development environment — local app against local docker Supabase + FalkorDB.
# Loaded by scripts/dev-launcher.mjs when invoked as `npm run dev`.
# Overrides .env and .env.local.
#
# These are the well-known Supabase demo keys (issuer "supabase-demo",
# fixed exp=1983812996). They are identical across every local supabase
# CLI install and are safe to commit.

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

FALKORDB_URL=redis://127.0.0.1:6389
FALKORDB_GRAPH=LIA_REGULATORY_GRAPH

# Gemini — live key lives in per-developer .env.local (gitignored), not here.
# The launcher loads .env.local first, so GEMINI_API_KEY is still picked up.

LIA_STORAGE_BACKEND=supabase
