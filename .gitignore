logs/heartbeat_*.md
frontend/logs/

# --- local scraper / runtime caches (volatile; regenerate on demand) ---
var/
frontend/var/

# --- artifact backups + skip-variants (operational temp; regenerate on ingest re-run) ---
artifacts/_backup_*/
artifacts/*.skip_llm_*
artifacts/*.v5_backup

# --- dev-only scaffolding (local preview pages + one-off verification scripts) ---
frontend/preview-*.html
frontend/scripts/verify-*.mjs
frontend/scripts/inspect-*.mjs

# --- SUIN ingestion large artifacts (regenerate from cache/ on ingest re-run) ---
artifacts/suin/**/*.log
artifacts/suin/**/*.jsonl
artifacts/suin/_production_push_*.log
artifacts/suin/_embedding_*.log
artifacts/graph_load_report.json
artifacts/parsed_articles.jsonl
artifacts/typed_edges.jsonl
artifacts/full_corpus_probe*/
artifacts/jobs/runtime/

# --- additive-corpus delta runtime output (regenerate each ingest run) ---
artifacts/intake/intake_*.jsonl
artifacts/delta_delta_*.json

# --- 100-Q eval raw runs (volatile; only __summary.json is tracked, per next_v4 §6) ---
evals/runs/*.jsonl
evals/runs/*_manifest.json
!evals/runs/*__summary.json
logs/parallel_*_extract.log
logs/pool_*.log
