logs/phase6_*.log
logs/staging_ab*.log
logs/*.current
logs/canonicalizer_*.log
logs/launch_*.log
logs/parallel_extract_*.log
logs/phase_*.log
logs/corpus_sync_*.log
logs/user_errors.jsonl
logs/campaign_*.log
